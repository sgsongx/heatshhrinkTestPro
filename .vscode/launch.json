{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "cwd": "${workspaceFolder}",
            "executable": "${config:buildFilePath}/App.elf",
            "name": "attach with JLink",
            "request": "attach",
            "type": "cortex-debug",
            "device": "${config:mcuCode}",
            "runToEntryPoint": "main",
            "showDevDebugOutput": "none",
            "servertype": "jlink",
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 2
            },
            "svdPath": "${config:svdPath}",
            "gdbPath": "arm-none-eabi-gdb.exe",
            // "serverpath": "D:/SSG_WORKSPACE/software/SEGGER/JLink_V818/JLinkGDBServerCL.exe",
            // "debugServer": 50000
        },
        {
            "cwd": "${workspaceFolder}",
            "executable": "${config:buildFilePath}/App.elf",
            "name": "start with JLink",
            "request": "launch",
            "type": "cortex-debug",
            "device": "${config:mcuCode}",
            "runToEntryPoint": "main",
            "showDevDebugOutput": "none",
            "servertype": "jlink",
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 2
            },
            "svdPath": "${config:svdPath}",
            "preLaunchTask": "build target",
            "gdbPath": "arm-none-eabi-gdb.exe",
            // "serverpath": "D:/SSG_WORKSPACE/software/SEGGER/JLink_V818/JLinkGDBServerCL.exe",
            // "debugServer": 50000
        },
    ]
}