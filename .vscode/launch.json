{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "cwd": "${workspaceFolder}",
            "executable": "./build/App.axf",
            "name": "attach with JLink",
            "request": "attach",
            "type": "cortex-debug",
            "device": "EFR32BG22CxxxF512",
            "runToEntryPoint": "main",
            "showDevDebugOutput": "none",
            "servertype": "jlink",
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 2
            },
            "svdPath": "./EFR32BG22C224F512GM32.svd"
            // "gdbPath": "D:/simlicity studio/developer/toolchains/gnu_arm/12.2.rel1_2023.7/bin/arm-none-eabi-gdb.exe",
            // "serverpath": "D:/SSG_WORKSPACE/software/SEGGER/JLink_V818/JLinkGDBServerCL.exe",
            // "debugServer": 50000
        },
        {
            "cwd": "${workspaceFolder}",
            "executable": "./build/App.axf",
            "name": "start with JLink",
            "request": "launch",
            "type": "cortex-debug",
            "device": "EFR32BG22CxxxF512",
            "runToEntryPoint": "main",
            "showDevDebugOutput": "none",
            "servertype": "jlink",
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 2
            },
            // "svdPath": "./EFR32BG22C224F512GM32.svd",
            "preLaunchTask": "build target"
            // "gdbPath": "D:/simlicity studio/developer/toolchains/gnu_arm/12.2.rel1_2023.7/bin/arm-none-eabi-gdb.exe",
            // "serverpath": "D:/SSG_WORKSPACE/software/SEGGER/JLink_V818/JLinkGDBServerCL.exe",
            // "debugServer": 50000
        },
    ]
}